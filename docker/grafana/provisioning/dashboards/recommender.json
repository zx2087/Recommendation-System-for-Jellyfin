{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""}
  ],
  "title": "Jellyfin Recommender",
  "uid": "jellyfin-recommender-v1",
  "description": "Multiworker ONNX serving: latency, fallback rate, throughput",
  "tags": ["jellyfin", "ml", "recommender"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": {"from": "now-30m", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum(rate(recommend_requests_total[1m])) by (mode)",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"lineWidth": 2}}}
    },
    {
      "id": 2,
      "title": "Fallback Rate (%)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "100 * sum(rate(recommend_requests_total{mode=\"fallback\"}[1m])) / (sum(rate(recommend_requests_total[1m])) > 0)",
          "legendFormat": "fallback %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 10},
            {"color": "red", "value": 30}
          ]},
          "custom": {"lineWidth": 2}
        }
      }
    },
    {
      "id": 3,
      "title": "Latency — p50 / p95 / p99 (ms)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(recommend_request_latency_seconds_bucket{mode=\"model\"}[1m])) by (le)) * 1000", "legendFormat": "p50 (ms)", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum(rate(recommend_request_latency_seconds_bucket{mode=\"model\"}[1m])) by (le)) * 1000", "legendFormat": "p95 (ms)", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum(rate(recommend_request_latency_seconds_bucket{mode=\"model\"}[1m])) by (le)) * 1000", "legendFormat": "p99 (ms)", "refId": "C"},
        {"expr": "5000", "legendFormat": "5s threshold", "refId": "D"}
      ],
      "fieldConfig": {
        "defaults": {"unit": "ms", "custom": {"lineWidth": 2}},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "5s threshold"},
            "properties": [
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}},
              {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [8, 4]}}
            ]
          }
        ]
      }
    },
    {
      "id": 4,
      "title": "Fallback Breakdown by Reason (req/s)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "sum(rate(fallback_used_total[1m])) by (reason)", "legendFormat": "{{reason}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"lineWidth": 2}}}
    },
    {
      "id": 5,
      "title": "Avg Candidate Count per Request",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "sum(rate(recommend_candidate_count_sum[1m])) / sum(rate(recommend_candidate_count_count[1m]))", "legendFormat": "avg candidates", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2}}}
    },
    {
      "id": 6, "title": "Current Request Rate", "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 24},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum(rate(recommend_requests_total[1m]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 7, "title": "Current p95 Latency", "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 24},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(recommend_request_latency_seconds_bucket{mode=\"model\"}[5m])) by (le)) * 1000", "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "ms", "thresholds": {"mode": "absolute", "steps": [
          {"color": "green", "value": null}, {"color": "yellow", "value": 1000}, {"color": "red", "value": 5000}
        ]}}
      }
    },
    {
      "id": 8, "title": "Current Fallback Rate", "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 24},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "100 * sum(rate(recommend_requests_total{mode=\"fallback\"}[5m])) / (sum(rate(recommend_requests_total[5m])) > 0)", "refId": "A"}],
      "fieldConfig": {
        "defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [
          {"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 30}
        ]}}
      }
    },
    {
      "id": 9, "title": "Total Requests (last 5m)", "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 24},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum(increase(recommend_requests_total[5m]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource", "type": "datasource", "query": "prometheus",
        "current": {"selected": true, "text": "Prometheus", "value": "Prometheus"},
        "hide": 0, "label": "Datasource"
      }
    ]
  }
}
